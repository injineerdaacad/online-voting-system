{
  "expo": {
    "name": "SNU Online Voting System",
    "slug": "ovs",
    "description": "An e-voting application built with Expo and React Native.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/SNU.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zayid.evoting"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.zayid.evoting"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/SNU.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ba385ef3-aae4-4b77-934d-466120282920"
      }
    },
    "owner": "injineerdaacad",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/ba385ef3-aae4-4b77-934d-466120282920"
    }
  }
}
