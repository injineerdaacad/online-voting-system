# Server
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database
DB_NAME=online_voting_system
MONGODB_URI=mongodb://127.0.0.1:27017
# Optional alternative key supported by seed scripts:
# DB=mongodb://127.0.0.1:27017/online-voting-system

# Auth
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRE=7d

# CORS / Socket
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,exp://localhost:8081,https://online-voting-system-*.vercel.app

# University API (optional)
UNIVERSITY_API_URL=https://university-api.example.com
UNIVERSITY_API_TIMEOUT=10000
UNIVERSITY_EMAIL_DOMAIN=example.edu

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Gemini (optional)
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=200
AI_ASSISTANT_RATE_LIMIT_MAX=5
GEMINI_DAILY_LIMIT=50

# Email (optional)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-app-password
EMAIL_FROM=noreply@example.com

# Seeds (optional)
SEED_SUPER_ADMIN_EMAIL=admin@example.com

# REST API test variables (used by backend/rest-api*.http)
BASE_URL=http://localhost:5000

OVS_STUDENT_ID=YOUR_STUDENT_ID
OVS_STUDENT_PASSWORD=YOUR_STUDENT_PASSWORD
OVS_ADMIN_USERNAME=YOUR_ADMIN_USERNAME
OVS_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD
